# ArenaVault Environment Configuration
# Copy this file to .env and update the values for your environment

# ============================================
# PostgreSQL Configuration
# ============================================
# The port on the HOST machine where PostgreSQL will be exposed
# If 5432 is already in use, change this to another port (e.g., 5433)
POSTGRES_HOST_PORT=5432

# ============================================
# Backend API Configuration
# ============================================
# The URL where the backend API is accessible
# For local development: http://localhost:5000/api
# For Docker network: http://arenavault-api:5000/api
# For remote server: http://YOUR_SERVER_IP:5000/api
API_URL=http://localhost:5000/api

# ============================================
# Database Connection (for reference)
# ============================================
# This is used by the backend service internally
# Format: Host=postgres;Database=arenavaultdb;Username=postgres;Password=ArenaVault2024!
DATABASE_URL=Host=postgres;Database=arenavaultdb;Username=postgres;Password=ArenaVault2024!

# ============================================
# Frontend Configuration
# ============================================
# The port where the frontend web UI will be exposed
FRONTEND_HOST_PORT=4200

# ============================================
# Backend Configuration
# ============================================
# The port where the backend API will be exposed
BACKEND_HOST_PORT=5000
