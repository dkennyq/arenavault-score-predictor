# Environment Variables Template
# Copy this file to .env and fill in your values
# DO NOT commit .env file to git!

# ===================================
# SQL Server Configuration
# ===================================
ACCEPT_EULA=Y
SA_PASSWORD=YourSecurePasswordHere123!
MSSQL_PID=Developer

# ===================================
# Backend API Configuration
# ===================================
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5000

# Database Connection String
# For local: Server=localhost;Database=ArenaVaultDB;...
# For Railway: Server=sqlserver.railway.internal;Database=ArenaVaultDB;...
# For Azure: Use Azure SQL connection string
ConnectionStrings__DefaultConnection=Server=localhost;Database=ArenaVaultDB;User Id=sa;Password=YourSecurePasswordHere123!;TrustServerCertificate=True;

# ===================================
# Frontend Configuration
# ===================================
# API URL that frontend will call
# For local: http://localhost:5000
# For Railway: https://your-api.railway.app
# For Azure: https://your-api.azurecontainerapps.io
API_URL=http://localhost:5000

# ===================================
# Production Deployment (Railway)
# ===================================
# RAILWAY_PROJECT_ID=your-project-id
# RAILWAY_TOKEN=your-railway-token

# ===================================
# Production Deployment (Azure)
# ===================================
# AZURE_CREDENTIALS={"clientId":"...","clientSecret":"...","subscriptionId":"...","tenantId":"..."}
# ACR_USERNAME=your-acr-username
# ACR_PASSWORD=your-acr-password
# AZURE_SQL_CONNECTION_STRING=Server=tcp:your-server.database.windows.net,1433;Database=ArenaVaultDB;...
