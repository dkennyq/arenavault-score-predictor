# Environment Variables Template
# Copy this file to .env and fill in your values
# DO NOT commit .env file to git!

# ===================================
# PostgreSQL Configuration
# ===================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=YourSecurePasswordHere123!
POSTGRES_DB=arenavaultdb

# ===================================
# Backend API Configuration
# ===================================
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5000

# Database Connection String
# For local: Host=localhost;Database=arenavaultdb;Username=postgres;Password=...
# For Railway: Host=postgres.railway.internal;Database=arenavaultdb;Username=postgres;Password=${PGPASSWORD}
# Railway auto-injects PGHOST, PGPORT, PGDATABASE, PGUSER, PGPASSWORD
ConnectionStrings__DefaultConnection=Host=localhost;Database=arenavaultdb;Username=postgres;Password=YourSecurePasswordHere123!

# ===================================
# Frontend Configuration
# ===================================
# API URL that frontend will call
# For local: http://localhost:5000
# For Railway: https://your-api.railway.app
API_URL=http://localhost:5000

# ===================================
# Production Deployment (Railway)
# ===================================
# RAILWAY_PROJECT_ID=your-project-id
# RAILWAY_TOKEN=your-railway-token

# ===================================
# Production Deployment (Azure)
# ===================================
# AZURE_CREDENTIALS={"clientId":"...","clientSecret":"...","subscriptionId":"...","tenantId":"..."}
# ACR_USERNAME=your-acr-username
# ACR_PASSWORD=your-acr-password
# AZURE_SQL_CONNECTION_STRING=Host=your-server.postgres.database.azure.com;Database=arenavaultdb;...
